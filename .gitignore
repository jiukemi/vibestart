# Dependencies & build output
node_modules/
dist/
dist-ssr/
mirror-out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Secrets & credentials — never commit
.env
.env.*
!.env.example
cookies.txt
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json
**/GITEE_TOKEN*
**/GH_TOKEN*

# Local / machine-specific
*.local
.DS_Store
Thumbs.db
Desktop.ini

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript / test
*.tsbuildinfo
coverage/

# Tauri / Rust (src-tauri/target is in src-tauri/.gitignore)
src-tauri/target/

# Release artifacts (local builds)
*.dmg
*.app
*.msi
*.exe
!site/**

# OS / temp
*.bak
*.tmp
*~

# Promo / video editing (Remotion, rendered clips, local assets)
video/
*.wav
*.m4a

