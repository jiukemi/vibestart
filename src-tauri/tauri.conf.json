{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeStart",
  "mainBinaryName": "VibeStart",
  "version": "0.1.6",
  "identifier": "com.hwh.vibestart",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeStart",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "macOS": {
      "bundleName": "VibeStart"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/content/packs/": "content/packs/",
      "resources/mirrors.json": "mirrors.json"
    }
  }
}
